# Required
# Single settings selector used by manage.py / WSGI / ASGI
DJANGO_SETTINGS_MODULE=core.settings_production
DJANGO_SECRET_KEY=replace-with-long-random-secret
DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# Optional (defaults to https://<host> from DJANGO_ALLOWED_HOSTS)
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Database
# Use PostgreSQL in production
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=car_sales
DJANGO_DB_USER=car_sales_user
DJANGO_DB_PASSWORD=replace-with-strong-password
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432
DJANGO_DB_CONN_MAX_AGE=60
DJANGO_DB_CONNECT_TIMEOUT=10

# HTTPS and security hardening
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=true
DJANGO_USE_X_FORWARDED_PROTO=true
DJANGO_USE_X_FORWARDED_HOST=true
DJANGO_WEBSOCKET_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# JWT hardening
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=true
JWT_BLACKLIST_AFTER_ROTATION=true
JWT_AUDIENCE=car-sales-clients
JWT_ISSUER=car-sales-platform

# DRF API throttling
DRF_THROTTLE_ANON=120/minute
DRF_THROTTLE_USER=240/minute
DRF_THROTTLE_AUTH_TOKEN_BURST=10/minute
DRF_THROTTLE_AUTH_TOKEN_SUSTAINED=60/hour
DRF_THROTTLE_AUTH_REFRESH_BURST=20/minute
DRF_THROTTLE_AUTH_REFRESH_SUSTAINED=200/hour

# Export anomaly detection
SECURITY_EXPORT_WINDOW_SECONDS=600
SECURITY_EXPORT_ALERT_THRESHOLD=5

# Hidden platform-admin login guard (unified login page)
SECURITY_PLATFORM_LOGIN_WINDOW_SECONDS=900
SECURITY_PLATFORM_LOGIN_MAX_ATTEMPTS=5

# Shared cache (recommended: Redis) for throttling and security windows across workers
DJANGO_CACHE_URL=redis://127.0.0.1:6379/2

# Logging
DJANGO_LOG_LEVEL=INFO

# Google OAuth (required for login/register with Google verification)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://example.com/auth/google/callback/

# Celery + Redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500
